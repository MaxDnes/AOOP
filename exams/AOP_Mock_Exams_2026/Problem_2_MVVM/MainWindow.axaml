<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="BoxCodeBehind.MainWindow"
        Title="BoxCodeBehind">
        <StackPanel Margin="50" Spacing="8">
            <Rectangle x:Name="Box" Fill="SteelBlue" Width="120" Height="80"></Rectangle>
            <ComboBox SelectedIndex="0" x:Name="ColorSelector"></ComboBox>
            <TextBlock Text="Width"></TextBlock>
            <Slider x:Name="WidthSlider" Minimum="20" Maximum="400" Value="120"></Slider>
            <TextBlock Text="Height"></TextBlock>
            <Slider x:Name="HeightSlider" Minimum="20" Maximum="400" Value="80"></Slider>
            <Button x:Name="ResetButton">Reset</Button>
            <TextBlock x:Name="Output"></TextBlock>
        </StackPanel>
</Window>
