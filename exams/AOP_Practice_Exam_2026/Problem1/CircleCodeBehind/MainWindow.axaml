<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CircleCodeBehind.MainWindow"
        Title="CircleCodeBehind">
        <StackPanel Margin="50">
            <Ellipse x:Name="Circle" Fill="green" Height="50" Width="50"></Ellipse>
            <ComboBox SelectedIndex="0" x:Name="ColorSelector"></ComboBox>
            <Slider x:Name="SizeSlider" Minimum="50" Maximum="500" Value="50"></Slider>
            <Button x:Name="ResetButton">Reset</Button>
            <TextBlock x:Name="Output"></TextBlock>
        </StackPanel>
</Window>
